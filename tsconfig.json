{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["es2024", "dom"],
    "paths": { "sefirot/*": ["./lib/*"], "*": ["./*"] },
    "types": ["@types/node", "vitest/globals"]
  },
  "include": ["*.config.ts", "docs", "docs/.vitepress/**/*", "env.d.ts", "lib", "stories", "tests"],
  "exclude": ["**/dist/**", "node_modules"]
}
